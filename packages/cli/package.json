{
  "name": "@xscope/cli",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "xscope": "./dist/index.js"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun --minify && chmod +x ./dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@xscope/shared": "workspace:*"
  }
}
