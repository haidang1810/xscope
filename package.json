{
  "name": "xscope",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:cli": "bun run --filter @xscope/cli dev",
    "dev:dashboard": "bun run --filter @xscope/dashboard dev",
    "build": "bun run --filter @xscope/dashboard build",
    "typecheck": "bun run --filter '*' typecheck"
  }
}
